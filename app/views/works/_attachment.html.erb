<% if work.documents.attached? %>
  <div class="container">
    <div class="row">
      <hr>
      <% work.documents.in_groups_of(3, false).each do |group| %>
        <div class="col-lg-6 col-md-6 mb-4">
          <% group.each do |document| %>
            <div class="mb-1">
              <% if document.blob.filename.to_s.match(/\.pdf/) %>
                <%= link_to image_tag("filetype-pdf.svg",   size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% elsif document.blob.filename.to_s.match(/\.doc/) %>
                <%= link_to image_tag("filetype-doc.svg",   size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% elsif document.blob.filename.to_s.match(/\.docx/) %>
                <%= link_to image_tag("filetype-docx.svg",  size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% elsif document.blob.filename.to_s.match(/\.xls/) %>
                <%= link_to image_tag("filetype-xls.svg",   size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% elsif document.blob.filename.to_s.match(/\.xlsx/) %>
                <%= link_to image_tag("filetype-xls.svg",   size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% elsif document.blob.filename.to_s.match(/\.jpg/) %>
                <%= link_to image_tag("filetype-jpg.svg",   size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% else %>
                <%= link_to image_tag("file-download.svg",  size: '24'), rails_blob_path(document, disposition: :attachment) %>
              <% end %>
              <%= document.blob.filename.to_s.gsub(/\.[a-z]+/,'').match(/^.{0,45}\b/)[0] %><br>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>