<% provide :page_title, 'Works' %>
<% currently_at 'Works'%>
<main class="my-5">
  <div class="container">
    <div class="text-center">
      <h1 class="mb-5">
        <strong>Works</strong>
        <%= link_to '+', new_work_path,
                                   class: 'btn btn-outline-dark',
                                   data: { turbo_frame: dom_id(Work.new) } %>
      </h1>
        <div class="my-3"
          <%= turbo_frame_tag Work.new %>
        </div>
      <div class="row">
        <%= render 'work' %>
      </div>
    </div>
</main>


