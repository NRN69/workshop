<% @works.each do |work|  %>
  <div class="col-lg-4 col-md-6 mb-4">
    <div class="card">
      <div class="bg-image hover-overlay ripple" data-mdb-ripple-color="light">
        <div class="img-fluid">
          <%= link_to image_tag(work.img.url,
                                size: '414x290'), work_path(work) %>
        </div>
        <div class="mask"
             style="background-color: rgba(251, 251, 251, 0.15);">
        </div>
      </div>
      <div class="card-body">
        <h2 class="card-title">
          <%= link_to work.title.capitalize, work_path(work),
                      class: 'text-decoration-none text-reset' %>
        </h2>
        <p class="card-text text-end">
          <%= link_to 'Edit', edit_work_path(work),
                      class: 'btn btn-light btn-sm' %>
          <%= link_to 'Delete', work_path(work),
                      data: {'turbo-method': :delete, 'turbo-confirm': 'Are you sure?'},
                      class: 'btn btn-light btn-sm' %>
        </p>
      </div>
    </div>
  </div>
<% end %>