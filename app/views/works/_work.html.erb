<% @works.each do |work|  %>
  <div class="col-lg-4 col-md-6 mb-4">
    <div class="card">
      <div class="bg-image hover-overlay ripple" data-mdb-ripple-color="light">
        <div class="img-fluid">
          <%= image_tag(work.img.url, size: '414x290') %>
        </div>
        <div class="mask" style="background-color: rgba(251, 251, 251, 0.15);"></div>
      </div>
      <div class="card-body">
        <h2 class="card-title">
          <%= work.title.capitalize %>
        </h2>
        <p class="card-text">
          <%= link_to 'Edit', edit_work_path(work) %>
          <%= link_to 'Delete', work_path(work),data: {'turbo-method': :delete, 'turbo-confirm': "Are you sure?"}%>
          <%= link_to 'Read', work_path(work) %>
        </p>
      </div>
    </div>
  </div>
<% end %>