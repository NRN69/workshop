<%= provide :main_menu do %>
  <header class="p-1 bg-white text-dark">
    <div class="container-fluid">
      <nav class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
        <ul class="nav col-12 col-lg-auto me-lg-auto mb-1 justify-content-center mb-md-0">
            <li>
              <%= nav_tab image_tag("house-fill.svg", size: '22', alt: 'Home'), root_path,
                          class: "nav-link", current_page: current_page %>
            </li>
            <li>
              <%= nav_tab 'Works', works_path,
                          class: 'nav-link px-2 my-1', current_page: current_page %>
            </li>
            <li>
              <%= nav_tab 'Posts', posts_path,
                          class: 'nav-link px-2 my-1', current_page: current_page %>
            </li>
            <li>
              <%= nav_tab 'Contacts', contacts_path,
                          class: 'nav-link px-2 my-1', current_page: current_page %>
            </li>
        </ul>

        <ul class="nav col-12 col-lg-auto mb-1 mb-md-0">
          <li class="dropdown">


            <ul class="dropdown-menu">
            </ul>
          </li>
        </ul>

        <ul class="nav col-12 col-lg-auto mb-1 mb-md-0">
          <% if user_signed_in? %>
            <li class="dropdown">
              <%= link_to '#',
                          class: 'nav-link px-2 dropdown-toggle text-dark',
                          data: {"bs-toggle": 'dropdown'} do %>
                <% if current_user.admin? %>
                <%= image_tag("gear-fill.svg", size: '24') %>
                <% else %>
                  <%= current_user.email %>
                <% end %>
              <% end %>

              <ul class="dropdown-menu">
                <li>
                  <%= link_to 'Edit', edit_user_registration_path,
                              class: 'dropdown-item' %>
                </li>

                <li><hr class="dropdown-divider"></li>

                <li>
                  <%= link_to 'Exit', destroy_user_session_path,
                              class: 'dropdown-item',
                              data: {turbo_method: :delete} %>
                </li>
              </ul>
            </li>
          <% else %>
            <li><button type="button" class="btn btn-default btn-circle btn-sm" data-bs-toggle="modal" data-bs-target="#sign_in">
              <%= image_tag("person-circle.svg", size: '22') %></li>

                <%= render 'shared/sign_in' %>

          <% end %>
        </ul>
      </nav>
    </div>
  </header>
<% end %>
