<%= provide :main_menu do %>
  <header class="p-2 bg-white text-white">
    <div class="container-fluid">
      <nav class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
        <ul class="nav col-12 col-lg-auto me-lg-auto mb-1 justify-content-center mb-md-0">
            <li>
              <%= nav_tab 'Home', root_path,
                          class: "nav-link", current_page: current_page %>
            </li>
            <li>
              <%= nav_tab 'Works', works_path,
                          class: 'nav-link px-2', current_page: current_page %>
            </li>
            <li>
              <%= nav_tab 'Posts', posts_path,
                          class: 'nav-link px-2', current_page: current_page %>
            </li>
            <li>
              <%= nav_tab 'Contacts', contacts_path,
                          class: 'nav-link px-2', current_page: current_page %>
            </li>
        </ul>
        <ul class="nav col-12 col-lg-auto mb-2 mb-md-0">
          <li class="dropdown">


            <ul class="dropdown-menu">
            </ul>
          </li>
        </ul>

        <ul class="nav col-12 col-lg-auto mb-2 mb-md-0">
          <% if user_signed_in? %>
            <li class="dropdown">
              <%= link_to '#',
                          class: 'nav-link px-2 dropdown-toggle text-white',
                          data: {"bs-toggle": 'dropdown'} do %>
                <%= current_user.name_or_email %>
              <% end %>

              <ul class="dropdown-menu">
                <li>
                  <%= link_to 'Edit', edit_user_registration,
                              class: 'dropdown-item' %>
                </li>

                <li><hr class="dropdown-divider"></li>

                <li>
                  <%= link_to 'Exit', destroy_user_session_path,
                              class: 'dropdown-item', data: {turbo_method: :delete} %>
                </li>
              </ul>
            </li>
          <% else %>
            <li><%= nav_tab 'Enter', new_user_session_path,
                            class: 'nav-link px-2', current_page: current_page %></li>

            <li><%= nav_tab 'Registration', new_user_registration_path,
                            class: 'nav-link px-2', current_page: current_page %></li>
          <% end %>
        </ul>
      </nav>
    </div>
  </header>
<% end %>