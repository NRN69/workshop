<% provide :page_title, 'Posts' %>
<% currently_at 'Posts'%>
<main class="my-5">
  <div class="container">
    <div class="text-center">
      <h1 class="mb-5">
        <strong>Posts</strong>
        <%= link_to '+', new_post_path,
                                   class: 'btn btn-outline-dark',
                                   data: { turbo_frame: dom_id(Post.new) } %>
      </h1>
      <div class="my-3"
        <%= turbo_frame_tag Post.new %>
      </div>
      <div class="row">
        <%= render 'post' %>
      </div>
      <%= render 'posts/pagination' %>
    </div>
</main>