<% provide :page_title, t('posts.new.title') %>
<% currently_at 'Post' %>
<main class="my-5">
  <div class="container">
    <div class="text-center">
      <h1 class="mb-5">
        <strong><%= t('posts.new.title') %></strong>
      </h1>
      <div class="row">
        <div class="col-lg-12 col-md-6 mb-4">

           <%= render 'form', post: @post %>

        </div>
      </div>
    </div>
  </div>
</main>